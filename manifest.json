{
  "manifest_version": 3,
  "name": "TabShelf",
  "version": "1.0.0",
  "key": "",
  "description": "Safely archive inactive tabs and keep reusable notes close at hand.",
  "minimum_chrome_version": "116",
  "permissions": ["tabs", "storage", "alarms", "sidePanel", "contextMenus", "tabGroups"],
  "background": { "service_worker": "background/service-worker.js", "type": "module" },
  "action": { "default_title": "Open TabShelf", "default_icon": "icons/icon.svg" },
  "side_panel": { "default_path": "sidepanel/index.html" },
  "commands": {
    "open-tabshelf": {
      "suggested_key": { "default": "Ctrl+Shift+Y", "mac": "MacCtrl+Shift+Y" },
      "description": "Open TabShelf"
    }
  },
  "icons": { "128": "icons/icon.svg" }
}
